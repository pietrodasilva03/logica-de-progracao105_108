programa {
  funcao inicio() {
    cadeia nomeProduto[3]
    real precoUnitarios[3]

    para(inteiro i = 0 ; i< 3 ; i++){
    
    faca{

      escreva("Digite" , i + 1 , "ª produto :" )
      leia(nomeProduto)
  
    }enquanto(precoUnitarios < 0)

    faca{
      
      escreva("Digite o preço unitário:")
      leia(precoUnitarios)

    }enquanto(precoUnitarios <0)

    
    }
    
  }
}